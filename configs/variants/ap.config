# AP Mode: mesh-capable WiFi with minimal footprint

# WiFi (mesh support)
CONFIG_PACKAGE_wpad-mesh-mbedtls=y

# Disable router components (set to module so users can install if needed)
CONFIG_PACKAGE_dnsmasq=m
CONFIG_PACKAGE_odhcpd=m
CONFIG_PACKAGE_odhcpd-ipv6only=m
CONFIG_PACKAGE_odhcp6c=m
CONFIG_PACKAGE_firewall4=m
CONFIG_PACKAGE_nftables=m
CONFIG_PACKAGE_kmod-nft-offload=m
CONFIG_PACKAGE_ppp=m
CONFIG_PACKAGE_ppp-mod-pppoe=m
CONFIG_PACKAGE_luci-app-firewall=m
CONFIG_PACKAGE_luci-proto-ipv6=m
CONFIG_PACKAGE_luci-proto-ppp=m

# Mesh (802.11s + usteer)
CONFIG_PACKAGE_usteer=y
CONFIG_PACKAGE_luci-app-usteer=y

# LuCI minimal (no firewall, no proto modules)
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci=m
