From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CrazyBoyFeng <crazyboyfeng@gmail.com>
Date: Fri, 20 Jun 2026 00:00:00 +0800
Subject: [PATCH] qualcommax: ipq50xx: pz-l8: add caldata entries

PR #21495 adds cmcc,pz-l8 to the ath11k caldata hotplug script but in a
"bare" form (caldata_extract only). This is incomplete - ath11k needs
the full caldata handling sequence (caldata_extract + MAC patching +
regdomain removal + macflag setting) to work correctly. Without it,
ath11k uses a random MAC on every boot and may have wrong regdomain.

This patch inserts cmcc,pz-l8 case blocks with the full caldata
handling for both radios:
  - 2.4GHz (IPQ5018): offset 0x1000, MAC = label_mac + 2
  - 5GHz (QCN6122):   offset 0x26800, MAC = label_mac + 3

Signed-off-by: CrazyBoyFeng <crazyboyfeng@gmail.com>

--- a/target/linux/qualcommax/ipq50xx/base-files/etc/hotplug.d/firmware/11-ath11k-caldata
+++ b/target/linux/qualcommax/ipq50xx/base-files/etc/hotplug.d/firmware/11-ath11k-caldata
@@ -48,6 +48,13 @@ case "$FIRMWARE" in
     xiaomi,ax6000)
         caldata_extract "0:art" 0x1000 0x20000
         ;;
+    cmcc,pz-l8)
+        caldata_extract "0:art" 0x1000 0x20000
+        label_mac=$(mtd_get_mac_binary 0:art 0)
+        ath11k_patch_mac $(macaddr_add $label_mac 2) 0
+        ath11k_remove_regdomain
+        ath11k_set_macflag
+        ;;
     yuncore,ax830|\
     yuncore,ax850)
         caldata_extract "0:ART" 0x1000 0x20000
@@ -95,6 +102,13 @@ case "$FIRMWARE" in
         ath11k_remove_regdomain
         ath11k_set_macflag
         ;;
+    cmcc,pz-l8)
+        caldata_extract "0:art" 0x26800 0x20000
+        label_mac=$(mtd_get_mac_binary 0:art 0)
+        ath11k_patch_mac $(macaddr_add $label_mac 3) 0
+        ath11k_remove_regdomain
+        ath11k_set_macflag
+        ;;
     yuncore,ax830)
         caldata_extract "0:ART" 0x4c000 0x20000
         label_mac=$(mtd_get_mac_binary 0:ART 0)
